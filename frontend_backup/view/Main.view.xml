<mvc:View
	controllerName="com.sgtin.lifecycle.controller.Main"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:f="sap.f"
	xmlns:card="sap.f.cards">
	<Page
		id="main"
		title="{i18n>appTitle}"
		showNavButton="false">
		<content>
			<VBox class="sapUiSmallMargin">
				<f:GridContainer>
					<!-- Purchase Orders Card -->
					<f:Card class="sapUiMediumMargin">
						<f:header>
							<card:Header
								title="{i18n>purchaseOrders}"
								subtitle="{i18n>managePurchaseOrders}"
								iconSrc="sap-icon://sales-order"/>
						</f:header>
						<f:content>
							<VBox class="sapUiSmallMargin">
								<Text text="{i18n>purchaseOrdersDesc}" class="sapUiSmallMarginBottom"/>
								<Button
									text="{i18n>manage}"
									type="Emphasized"
									press="onNavigateToPurchaseOrders"/>
							</VBox>
						</f:content>
					</f:Card>

					<!-- Goods Receipt Card -->
					<f:Card class="sapUiMediumMargin">
						<f:header>
							<card:Header
								title="{i18n>goodsReceipt}"
								subtitle="{i18n>scanAndReceive}"
								iconSrc="sap-icon://inventory"/>
						</f:header>
						<f:content>
							<VBox class="sapUiSmallMargin">
								<Text text="{i18n>goodsReceiptDesc}" class="sapUiSmallMarginBottom"/>
								<Button
									text="{i18n>scanItems}"
									type="Emphasized"
									press="onNavigateToGoodsReceipt"/>
							</VBox>
						</f:content>
					</f:Card>

					<!-- Inventory Card -->
					<f:Card class="sapUiMediumMargin">
						<f:header>
							<card:Header
								title="{i18n>inventory}"
								subtitle="{i18n>viewSerializedStock}"
								iconSrc="sap-icon://product"/>
						</f:header>
						<f:content>
							<VBox class="sapUiSmallMargin">
								<Text text="{i18n>inventoryDesc}" class="sapUiSmallMarginBottom"/>
								<Button
									text="{i18n>viewInventory}"
									type="Emphasized"
									press="onNavigateToInventory"/>
							</VBox>
						</f:content>
					</f:Card>

					<!-- POS Card -->
					<f:Card class="sapUiMediumMargin">
						<f:header>
							<card:Header
								title="{i18n>pointOfSale}"
								subtitle="{i18n>processSales}"
								iconSrc="sap-icon://cart"/>
						</f:header>
						<f:content>
							<VBox class="sapUiSmallMargin">
								<Text text="{i18n>posDesc}" class="sapUiSmallMarginBottom"/>
								<Button
									text="{i18n>openPOS}"
									type="Emphasized"
									press="onNavigateToPOS"/>
							</VBox>
						</f:content>
					</f:Card>

					<!-- Chatbot Card -->
					<f:Card class="sapUiMediumMargin">
						<f:header>
							<card:Header
								title="{i18n>intelligentAssistant}"
								subtitle="{i18n>askQuestions}"
								iconSrc="sap-icon://message-information"/>
						</f:header>
						<f:content>
							<VBox class="sapUiSmallMargin">
								<Text text="{i18n>chatbotDesc}" class="sapUiSmallMarginBottom"/>
								<Button
									text="{i18n>openChatbot}"
									type="Emphasized"
									press="onNavigateToChatbot"/>
							</VBox>
						</f:content>
					</f:Card>
				</f:GridContainer>
			</VBox>
		</content>
	</Page>
</mvc:View>
