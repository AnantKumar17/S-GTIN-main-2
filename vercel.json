{
  "buildCommand": "cd shared && npm install && cd ../services/po-service && npm install",
  "installCommand": "npm install",
  "env": {
    "PORT": "3002",
    "DB_HOST": "@db_host",
    "DB_PORT": "@db_port",
    "DB_NAME": "@db_name",
    "DB_USER": "@db_user",
    "DB_PASSWORD": "@db_password",
    "MANDT": "100",
    "API_KEY": "@api_key",
    "SGTIN_SERVICE_URL": "@sgtin_service_url"
  }
}
